<file path="lib/SafeContext.tsx">
 1: /**
 2:  * Demonstrates the SAFE context pattern — immune to the render-order bug.
 3:  *
 4:  * The difference from StrictContext:
 5:  *   StrictContext  → createContext(null)  + hard throw on null
 6:  *   SafeContext    → createContext(default) with a real default value
 7:  *
 8:  * When the Edge streaming renderer calls the page before _app, useContext
 9:  * returns the DEFAULT VALUE instead of null. No throw, no crash — the
10:  * component renders with the default and updates after the provider mounts.
11:  *
12:  * This is how most well-written contexts work (react-query, next-themes,
13:  * zustand context, etc.). Flagsmith's useFlagsmith() is unusual in that
14:  * it explicitly throws rather than returning a default.
15:  *
16:  * Rule of thumb:
17:  *   - If the context CAN have a meaningful default → use one, skip the HOC
18:  *   - If the context MUST have server data (identity, flags, auth tokens)
19:  *     → it genuinely can't have a meaningful default → use the HOC pattern
20:  */
21: import React, { createContext, useContext, useState } from "react";
22: 
23: export interface SafeContextValue {
24:   theme: "light" | "dark";
25:   locale: string;
26:   featureReady: boolean;
27: }
28: 
29: // A real default — useContext returns this when no provider is in the tree.
30: // The render-order bug becomes harmless: worst case the component renders
31: // with defaults, then re-renders with real values once the provider mounts.
32: const DEFAULT: SafeContextValue = {
33:   theme: "light",
34:   locale: "en",
35:   featureReady: false,
36: };
37: 
38: const SafeCtx = createContext<SafeContextValue>(DEFAULT);
39: 
40: // No null check needed — context is never null.
41: export function useSafeContext(): SafeContextValue {
42:   return useContext(SafeCtx);
43: }
44: 
45: export function SafeContextProvider({
46:   children,
47:   serverValue,
48: }: {
49:   children: React.ReactNode;
50:   serverValue?: Partial<SafeContextValue>;
51: }) {
52:   const [value] = useState<SafeContextValue>({ ...DEFAULT, ...serverValue });
53:   return <SafeCtx.Provider value={value}>{children}</SafeCtx.Provider>;
54: }
</file>

