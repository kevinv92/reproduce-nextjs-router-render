<file path="lib/StrictContext.tsx">
 1: /**
 2:  * Mimics how flagsmith/react implements its context:
 3:  * - createContext(null) with no default value
 4:  * - useStrictContext() hard-throws if context is null
 5:  *
 6:  * This is the exact pattern that breaks when page renders
 7:  * before _app in Next.js 15 Pages Router + Edge runtime.
 8:  *
 9:  * Compare with flagsmith-js-client react.tsx:
10:  *   useFlagsmith()   → hard throws on null  (this file mimics this)
11:  *   useFlags()       → non-null assertion   (crashes with generic TypeError)
12:  *   useFlagsmithLoading() → optional chain  (silently returns undefined)
13:  */
14: import React, { createContext, useContext, useRef, useState } from "react";
15: 
16: export interface StrictContextValue {
17:   initialized: boolean;
18:   data: Record<string, boolean>;
19: }
20: 
21: // Initialized to null — no fallback. If a consumer runs before
22: // the provider mounts, useContext returns null.
23: const StrictCtx = createContext<StrictContextValue | null>(null);
24: 
25: // Hard-throws on null — exactly like useFlagsmith()
26: export function useStrictContext(): StrictContextValue {
27:   const ctx = useContext(StrictCtx);
28:   if (ctx === null) {
29:     throw new Error(
30:       "useStrictContext must be used within a StrictContextProvider"
31:     );
32:   }
33:   return ctx;
34: }
35: 
36: // Mimics how flagsmith/react initializes asynchronously.
37: // Accepts an optional serverState (pre-fetched in getServerSideProps by the
38: // withStrictContext HOC) so the context is never null on first render.
39: export function StrictContextProvider({
40:   children,
41:   serverState,
42: }: {
43:   children: React.ReactNode;
44:   serverState?: StrictContextValue;
45: }) {
46:   console.log({ ps: "Provider (inside _app)", phase: "render" });
47: 
48:   const [state, setState] = useState<StrictContextValue>(
49:     serverState ?? { initialized: false, data: {} }
50:   );
51: 
52:   // Simulate async init (like flagsmith.init()) — skipped when serverState
53:   // is provided because the state is already populated.
54:   React.useEffect(() => {
55:     if (serverState) return;
56:     setTimeout(() => {
57:       setState({ initialized: true, data: { feature_flag_a: true } });
58:     }, 50);
59:   }, []);
60: 
61:   return <StrictCtx.Provider value={state}>{children}</StrictCtx.Provider>;
62: }
</file>

<file path="lib/withStrictContext.tsx">
  1: /**
  2:  * HOC-based fix for the Next.js 15 Pages Router + Edge runtime render-order bug.
  3:  *
  4:  * Problem recap:
  5:  *   - _app.tsx wraps every page in StrictContextProvider
  6:  *   - Edge streaming renderer (renderToReadableStream) can call the page
  7:  *     component before _app's provider mounts → useContext returns null → throw
  8:  *
  9:  * Fix (mirrors the Flagsmith withPageFlags pattern from the Notion doc):
 10:  *   1. getServerContextState() — call in getServerSideProps; resolves the state
 11:  *      BEFORE React touches the component tree (no render-order risk)
 12:  *   2. withStrictContext(PageComponent) — HOC that wraps the page in its own
 13:  *      StrictContextProvider, seeded from serverContextState. The provider is
 14:  *      guaranteed to be in the tree before the page component renders.
 15:  *
 16:  * Why getServerSideProps is safe:
 17:  *   getServerSideProps runs completely outside the React render pipeline.
 18:  *   Its result is passed as props to the component tree — by the time React
 19:  *   starts rendering, the state is already sitting in pageProps. This holds
 20:  *   for both renderToString (Node) and renderToReadableStream (Edge).
 21:  */
 22: 
 23: import { useRef } from "react";
 24: import {
 25:   StrictContextProvider,
 26:   type StrictContextValue,
 27: } from "@/lib/StrictContext";
 28: 
 29: // ─── Server-side helper ───────────────────────────────────────────────────────
 30: 
 31: /**
 32:  * Resolves the context state on the server inside getServerSideProps.
 33:  *
 34:  * In a real Flagsmith app this is:
 35:  *   const flagsmith = createFlagsmithInstance()
 36:  *   await flagsmith.init({ environmentID: ..., identity: userId })
 37:  *   return flagsmith.getState()
 38:  *
 39:  * Here we simulate a network call with a short delay.
 40:  */
 41: export async function getServerContextState(
 42:   userId?: string
 43: ): Promise<StrictContextValue> {
 44:   // Simulate fetching feature flags from a remote service (~10 ms)
 45:   await new Promise((r) => setTimeout(r, 10));
 46: 
 47:   return {
 48:     initialized: true,
 49:     data: {
 50:       feature_flag_a: true,
 51:       promo_banner: userId !== undefined, // enabled only for logged-in users
 52:     },
 53:   };
 54: }
 55: 
 56: // ─── HOC ─────────────────────────────────────────────────────────────────────
 57: 
 58: /**
 59:  * Wraps a page component in its own StrictContextProvider seeded from
 60:  * serverContextState (the value returned by getServerContextState and passed
 61:  * through getServerSideProps → pageProps).
 62:  *
 63:  * Usage:
 64:  *   export default withStrictContext(MyPage)
 65:  *
 66:  *   export const getServerSideProps: GetServerSideProps = async () => ({
 67:  *     props: { serverContextState: await getServerContextState() },
 68:  *   })
 69:  */
 70: export function withStrictContext<P extends Record<string, unknown>>(
 71:   PageComponent: React.ComponentType<P>
 72: ) {
 73:   function WrappedPage({
 74:     serverContextState,
 75:     ...props
 76:   }: P & { serverContextState: StrictContextValue }) {
 77:     // Catch the most common mistake early: page uses withStrictContext but
 78:     // getServerSideProps forgot to return serverContextState. In production
 79:     // this would silently fall back to uninitialized state; in dev it throws
 80:     // immediately with a clear message pointing at the missing prop.
 81:     if (process.env.NODE_ENV === "development" && serverContextState == null) {
 82:       throw new Error(
 83:         `withStrictContext: serverContextState is missing from pageProps for ` +
 84:           `"${PageComponent.displayName ?? PageComponent.name}". ` +
 85:           `Add getServerSideProps that calls getServerContextState() and ` +
 86:           `returns { props: { serverContextState } }.`
 87:       );
 88:     }
 89: 
 90:     // useRef so createInstance isn't called on every render (mirrors
 91:     // the flagsmith HOC using useRef(createFlagsmithInstance()))
 92:     const stateRef = useRef(serverContextState);
 93: 
 94:     return (
 95:       <StrictContextProvider serverState={stateRef.current}>
 96:         <PageComponent {...(props as unknown as P)} />
 97:       </StrictContextProvider>
 98:     );
 99:   }
100: 
101:   WrappedPage.displayName = `withStrictContext(${
102:     PageComponent.displayName ?? PageComponent.name ?? "Component"
103:   })`;
104: 
105:   return WrappedPage;
106: }
</file>

