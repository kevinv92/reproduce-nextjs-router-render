 22: 
 23: const StrictCtx = createContext(null); // null default — no fallback value
 24: 
 25: function useStrictContext() {
 26:   const ctx = useContext(StrictCtx);
 27:   if (ctx === null) {
 28:     // This is verbatim what flagsmith-js-client/react.tsx does for useFlagsmith()
 29:     throw new Error(
 30:       "useStrictContext must be used within a StrictContextProvider"
 31:     );
 32:   }
 33:   return ctx;
 34: }
 35: 
 36: function StrictContextProvider({ children, value }) {
 37:   console.log("  [render] StrictContextProvider");
 38:   return createElement(StrictCtx.Provider, { value }, children);
 39: }
 40: 
 41: // ─── Components ───────────────────────────────────────────────────────────────
 42: 
 43: function PageComponent() {
 44:   console.log("  [render] PageComponent");
 45:   const ctx = useStrictContext(); // throws if context is null
 46:   return createElement("div", null, `flags: ${JSON.stringify(ctx)}`);
 47: }
