32: const root = join(__dirname, "..");
33: 
34: const indexPath = join(root, "pages", "index.tsx");
35: const appPath = join(root, "pages", "_app.tsx");
36: 
37: // Save originals
38: const originalIndex = readFileSync(indexPath, "utf8");
39: const originalApp = readFileSync(appPath, "utf8");
40: 
41: // Broken index.tsx — static (no getServerSideProps), uses strict context
42: const brokenIndex = `import { useStrictContext } from "@/lib/StrictContext";
43: 
44: // NO getServerSideProps — this is a STATIC page.
45: // next build will prerender it using react-dom-server.edge.production.js.
46: // Without a provider in the tree, useStrictContext() returns null → throws.
47: export default function Home() {
48:   const ctx = useStrictContext(); // throws during build-time prerender
49:   return <main><pre>{JSON.stringify(ctx)}</pre></main>;
50: }
51: `;
52: 
53: // Broken _app.tsx — no StrictContextProvider (simulates the missing-provider scenario)
54: const brokenApp = `import type { AppProps } from "next/app";
55: // No provider — the static index.tsx page has nothing above it when prerendered.
56: export default function App({ Component, pageProps }: AppProps) {
57:   return <Component {...pageProps} />;
58: }
59: `;
